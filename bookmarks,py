import json
import os
from datetime import datetime

from PyQt6.QtCore import QObject, pyqtSignal, Qt
from PyQt6.QtWidgets import (
    QWidget, QVBoxLayout, QHBoxLayout, QListWidget, QListWidgetItem,
    QPushButton, QLabel, QLineEdit, QMessageBox
)


BOOKMARKS_FILE = os.path.join(
    os.path.expanduser("~"), ".novabrowser", "bookmarks.json"
)


class BookmarkManager(QObject):

    bookmarks_changed = pyqtSignal()

    def __init__(self):
        super().__init__()
        self._bookmarks = []
        self._ensure_storage_dir()
        self.load()

    @staticmethod
    def _ensure_storage_dir():
        os.makedirs(os.path.dirname(BOOKMARKS_FILE), exist_ok=True)

    def load(self):
        if os.path.exists(BOOKMARKS_FILE):
            try:
                with open(BOOKMARKS_FILE, "r", encoding="utf-8") as f:
                    self._bookmarks = json.load(f)
            except (json.JSONDecodeError, OSError):
                self._bookmarks = []
        else:
            self._bookmarks = []

    def save(self):
        try:
            with open(BOOKMARKS_FILE, "w", encoding="utf-8") as f:
                json.dump(self._bookmarks, f, indent=2)
        except OSError:
            pass 

    def add(self, title: str, url: str) -> bool:
        if self.is_bookmarked(url):
            return False
        self._bookmarks.append({
            "title": title or url,
            "url": url,
            "added_at": datetime.now().isoformat(timespec="seconds"),
        })
        self.save()
        self.bookmarks_changed.emit()
        return True

    def remove(self, url: str):
        self._bookmarks = [b for b in self._bookmarks if b["url"] != url]
        self.save()
        self.bookmarks_changed.emit()

    def is_bookmarked(self, url: str) -> bool:
        return any(b["url"] == url for b in self._bookmarks)

    def toggle(self, title: str, url: str) -> bool:
        if self.is_bookmarked(url):
            self.remove(url)
            return False
        self.add(title, url)
        return True

    def all(self):
        return list(reversed(self._bookmarks)) 


class BookmarkPanel(QWidget):


    navigate_requested = pyqtSignal(str)

    def __init__(self, bookmark_manager: BookmarkManager, parent=None):
        super().__init__(parent)
        self.manager = bookmark_manager
        self._build_ui()
        self.manager.bookmarks_changed.connect(self.refresh)
        self.refresh()

    def _build_ui(self):
        layout = QVBoxLayout(self)
        layout.setContentsMargins(12, 12, 12, 12)
        layout.setSpacing(8)

        title = QLabel("Bookmarks")
        title.setObjectName("SectionTitle")
        layout.addWidget(title)

        self.search_box = QLineEdit()
        self.search_box.setPlaceholderText("Filter bookmarks...")
        self.search_box.textChanged.connect(self.refresh)
        layout.addWidget(self.search_box)

        self.list_widget = QListWidget()
        self.list_widget.itemDoubleClicked.connect(self._on_item_activated)
        layout.addWidget(self.list_widget)

        btn_row = QHBoxLayout()
        self.delete_btn = QPushButton("Remove Selected")
        self.delete_btn.setObjectName("DangerButton")
        self.delete_btn.clicked.connect(self._on_delete_clicked)
        btn_row.addWidget(self.delete_btn)
        layout.addLayout(btn_row)

    def refresh(self):
        query = self.search_box.text().lower().strip()
        self.list_widget.clear()
        for bm in self.manager.all():
            if query and query not in bm["title"].lower() and query not in bm["url"].lower():
                continue
            item = QListWidgetItem(f"{bm['title']}\n{bm['url']}")
            item.setData(Qt.ItemDataRole.UserRole, bm["url"])
            self.list_widget.addItem(item)

    def _on_item_activated(self, item: QListWidgetItem):
        url = item.data(Qt.ItemDataRole.UserRole)
        if url:
            self.navigate_requested.emit(url)

    def _on_delete_clicked(self):
        item = self.list_widget.currentItem()
        if not item:
            return
        url = item.data(Qt.ItemDataRole.UserRole)
        reply = QMessageBox.question(
            self, "Remove Bookmark",
            "Remove this bookmark?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No,
        )
        if reply == QMessageBox.StandardButton.Yes:
            self.manager.remove(url)
